<mujoco model="UIAA_101_Validation">
    <compiler angle="degree" coordinate="local" inertiafromgeom="auto"/>
    
    <option gravity="0 0 -9.81" timestep="0.002" integrator="RK4"/>
    
    <asset>
        <material name="rope_mat" rgba="0.8 0.2 0.2 1"/>
        <material name="mass_mat" rgba="0.2 0.2 0.8 1"/>
        <texture name="grid_tex" type="2d" builtin="checker" rgb1="0.8 0.8 0.8" rgb2="0.6 0.6 0.6" width="512" height="512"/>
        <material name="grid_mat" texture="grid_tex" texrepeat="20 20" reflectance="0.1" rgba="1 1 1 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 10" dir="0 0 -1"/>
        <geom name="floor" type="plane" pos="0 0 -1" size="5 5 0.1" material="grid_mat"/>
        
        <site name="anchor" pos="0 0 2.8" size="0.05"/>
        
        <body name="cylinder_mass" pos="0 0 4.8">
            <freejoint name="mass_free"/>
            <geom name="mass_geom" type="cylinder" mass="80" size="0.05 0.1" material="mass_mat"/>
            <site name="rope_attach" pos="0 0 0" size="0.02"/>
        </body>
    </worldbody>

    <tendon>
        <spatial name="tether" width="0.0045" material="rope_mat">
            <site site="anchor"/>
            <site site="rope_attach"/>
        </spatial>
    </tendon>
</mujoco>